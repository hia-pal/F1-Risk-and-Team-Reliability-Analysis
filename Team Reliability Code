print("=== TIME-BASED RELIABILITY ANALYSIS ===")

def analyze_team_by_eras(team_name, data):
    """Analyze team reliability across different time eras"""
    team_data = data[data['current_team'] == team_name].copy()

    if len(team_data) == 0:
        return f" Team '{team_name}' not found"

    # Define eras
    current_year = 2024
    eras = {
        'Last 5 Years (2020-2024)': (2020, 2024),
        '5 Years Before (2015-2019)': (2015, 2019),
        '5 Years Before That (2010-2014)': (2010, 2014),
        'Early 2000s (2000-2009)': (2000, 2009),
        '1990s Era': (1990, 1999),
        'Pre-1990': (1950, 1989)
    }

    print(f"\n{'='*70}")
    print(f"  ERA-BASED RELIABILITY: {team_name.upper()}")
    print(f"{'='*70}")

    era_results = {}

    for era_name, (start_year, end_year) in eras.items():
        era_data = team_data[(team_data['year'] >= start_year) & (team_data['year'] <= end_year)]

        if len(era_data) > 0:
            total_races = len(era_data)
            finished_races = len(era_data[era_data['is_dnf'] == False])  # Using is_dnf instead of finished_race
            reliability = finished_races / total_races

            # Performance metrics
            finished_in_era = era_data[era_data['is_dnf'] == False]
            avg_start = finished_in_era['grid'].mean()  # Using grid instead of startingPosition
            avg_finish = finished_in_era['position'].mean()  # Using position instead of finishingPosition

            era_results[era_name] = {
                'reliability': reliability,
                'races': total_races,
                'avg_start': avg_start,
                'avg_finish': avg_finish
            }

            # Grade for this era
            if reliability >= 0.90:
                grade = "A+"
            elif reliability >= 0.80:
                grade = "A"
            elif reliability >= 0.70:
                grade = "B"
            elif reliability >= 0.60:
                grade = "C"
            else:
                grade = "F"

            print(f"{era_name:<25} {reliability:>6.1%} {grade:<8} {total_races:>3} races")
            if not finished_in_era.empty:
                print(f"{' ':>25} Avg: {avg_start:.1f} → {avg_finish:.1f} ({avg_start - avg_finish:+.1f} pos)")
            else:
                print(f"{' ':>25} No finished races")
        else:
            print(f"{era_name:<25} {'No data':>12}")

    return era_results

