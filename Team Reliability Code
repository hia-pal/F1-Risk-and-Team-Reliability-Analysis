def analyze_all_teams_eras(data):
    """Analyze all current teams across eras with exact year ranges"""

    # Define eras that cover ALL years in dataset
    min_year = data['year'].min()
    max_year = data['year'].max()

    eras = {
        'Modern (2020-2024)': (2020, 2024),
        'Hybrid Era (2014-2019)': (2014, 2019),
        'V8 Era (2006-2013)': (2006, 2013),
        'V10 Era (1995-2005)': (1995, 2005),
        'Classic Era (1980-1994)': (1980, 1994),
        'Early Years (1950-1979)': (1950, 1979)
    }

    current_teams = ['Mercedes', 'Red Bull', 'Ferrari', 'McLaren', 'Alpine',
                    'Aston Martin', 'Williams', 'AlphaTauri', 'Alfa Romeo', 'Haas']

    # Create results dataframe
    era_results = {}

    for team in current_teams:
        team_data = data[data['current_team'] == team]
        team_results = {}

        for era_name, (start_year, end_year) in eras.items():
            era_data = team_data[(team_data['year'] >= start_year) & (team_data['year'] <= end_year)]

            if len(era_data) > 0:
                total_races = len(era_data)
                finished_races = len(era_data[era_data['is_dnf'] == False])
                reliability = (finished_races / total_races) * 100

                team_results[era_name] = {
                    'reliability': reliability,
                    'races': total_races,
                    'finished_races': finished_races
                }

        era_results[team] = team_results

    return era_results, eras

