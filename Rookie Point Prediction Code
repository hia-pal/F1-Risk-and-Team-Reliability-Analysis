Part 1: Setup and File Upload

import re, pandas as pd, numpy as np
from google.colab import files
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder, StandardScaler
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import classification_report, confusion_matrix, accuracy_score, roc_auc_score

def normalize_colname(s):
    s = str(s).strip().lower()
    s = re.sub(r"[^\w]+", "_", s)
    s = re.sub(r"_+","_", s)
    return s.strip("_")

# Upload (if not already uploaded)
print("Please upload your Excel file (F1 Revised.xlsx).")
uploaded = files.upload()
file_path = list(uploaded.keys())[0]
print("Using:", file_path)

Part 2: Load and Explore Sheets
# Read sheets
xls = pd.ExcelFile(file_path)
print("Available sheets:", xls.sheet_names)

# Find F1 sheet (prefer exact, else first)
f1_sheet = next((s for s in xls.sheet_names if "f1 data for drivers" in s.lower()), xls.sheet_names[0])
# Find F2 sheet by searching for 'f2' in sheet names
f2_sheet = next((s for s in xls.sheet_names if "f2" in s.lower()), None)
rookie_sheet = next((s for s in xls.sheet_names if "2025" in s.lower() and "rookie" in s.lower()), None)

print("Using F1 sheet:", f1_sheet)
print("Using F2 sheet:", f2_sheet)
print("Using rookie sheet (if any):", rookie_sheet)

# Load sheets
df_f1 = pd.read_excel(file_path, sheet_name=f1_sheet)
df_f1.columns = [normalize_colname(c) for c in df_f1.columns]

if f2_sheet:
    df_f2 = pd.read_excel(file_path, sheet_name=f2_sheet)
    df_f2.columns = [normalize_colname(c) for c in df_f2.columns]
else:
    df_f2 = None

# Quick peek
print("\nF1 cols:", df_f1.columns.tolist()[:30])
if df_f2 is not None:
    print("F2 cols:", df_f2.columns.tolist()[:30])


Part 3: Data Merging
                     # --- Merge F1 + F2 on driver name (robust) ---
# pick driver name columns
f1_driver_col = next((c for c in df_f1.columns if "driver" in c), None)
f2_driver_col = next((c for c in df_f2.columns if "driver" in c), None) if df_f2 is not None else None

if f1_driver_col is None:
    raise KeyError("No driver name column found in F1 sheet.")
if df_f2 is None or f2_driver_col is None:
    print("F2 sheet not found or has no driver column — proceeding with F1-only features.")
    df_merged = df_f1.copy()
else:
    # normalize names to lower for matching
    df_f1['_drv'] = df_f1[f1_driver_col].astype(str).str.strip().str.lower()
    df_f2['_drv2'] = df_f2[f2_driver_col].astype(str).str.strip().str.lower()
    df_merged = pd.merge(df_f1, df_f2, left_on='_drv', right_on='_drv2', how='left', suffixes=('_f1','_f2'))
    print("Merged shape:", df_merged.shape)


Part 4: Target Variable Creation
                      # --- Build target: scored_points (from F1 points column) ---
# try possible points column names
points_col = next((c for c in df_merged.columns if c in ("points","points_f1","points_f1.0")), None)
if points_col is None:
    # try any column containing 'point'
    points_col = next((c for c in df_merged.columns if "point" in c), None)
if points_col is None:
    raise KeyError("Could not find a points column in merged data.")
df_merged["points_f1"] = pd.to_numeric(df_merged[points_col], errors="coerce").fillna(0)
df_merged["scored_points"] = (df_merged["points_f1"] > 0).astype(int)
print("\nTarget distribution (scored_points):\n", df_merged["scored_points"].value_counts())

Part 5: Feature Selection
                       # --- Select features: F1 debut features + common F2 features if present ---
f1_features = ["debut_age","debut_year","debut_team","track_type","weather_condition",
               "no_of_seasons_competed","race_entries","race_starts","pole_positions",
               "race_wins","podiums","points"]
f2_features = ["wins","podiums_f2","total_no_of_races_they_have_raced","total_championships_titles_won_in_junior_series",
               "total_crashes_or_collisions","total_dnf_per_driver"]

# normalize choices to available columns
available = df_merged.columns.tolist()
features = [f for f in f1_features if f in available]
# try common F2 columns heuristically
for cand in ["wins","wins_f2","wins_f2.0","wins_f2_","podiums","podiums_f2","podiums_f2.0"]:
    if cand in available and cand not in features:
        features.append(cand)
# numeric crash/dnf totals if present
for cand in ["total_crashes_or_collisions","total_dnf_per_driver","total_dnf"]:
    if cand in available and cand not in features:
        features.append(cand)

print("\nFeatures used:", features)

Part 6: Data Preparation
            # --- Prepare data ---
df_model = df_merged.dropna(subset=["scored_points"]).copy()
X = df_model[features].copy()
y = df_model["scored_points"].copy()

# numeric fill
num_cols = [c for c in X.columns if pd.api.types.is_numeric_dtype(X[c])]
for c in num_cols:
    X[c] = X[c].fillna(X[c].median())

# categorical encode
cat_cols = [c for c in X.columns if c not in num_cols]
label_encoders = {}
for c in cat_cols:
    X[c] = X[c].fillna("missing").astype(str)
    le = LabelEncoder()
    X[c] = le.fit_transform(X[c])
    label_encoders[c] = le

# scale numeric
scaler = StandardScaler()
if num_cols:
    X[num_cols] = scaler.fit_transform(X[num_cols])

print("Data preparation completed.")
print("X shape:", X.shape)
print("y shape:", y.shape)

Part 7: Model Training and Evaluation
            # --- Train/test split & Logistic Regression ---
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.25, random_state=42, stratify=y)
model = LogisticRegression(max_iter=1000, class_weight='balanced')
model.fit(X_train, y_train)

# Evaluate
y_pred = model.predict(X_test)
y_proba = model.predict_proba(X_test)[:,1]
print("\nAccuracy:", round(accuracy_score(y_test, y_pred),4))
print("Confusion Matrix:\n", confusion_matrix(y_test, y_pred))
print("Classification Report:\n", classification_report(y_test, y_pred))
try:
    print("ROC AUC:", round(roc_auc_score(y_test, y_proba),4))
except:
    pass

# Feature importance (odds ratios)
coef = pd.Series(model.coef_[0], index=X.columns)
odds = np.exp(coef).sort_values(ascending=False)
print("\nTop predictors by odds ratio:\n", odds.head(15)


Part 8: Rookie Predictions (Optional)
      # --- Predict for 2025 rookies if sheet exists ---
if rookie_sheet:
    rookies = pd.read_excel(file_path, sheet_name=rookie_sheet)
    rookies.columns = [normalize_colname(c) for c in rookies.columns]
    # align features
    for f in features:
        if f not in rookies.columns:
            rookies[f] = 0
    for c in cat_cols:
        rookies[c] = rookies[c].fillna("missing").astype(str)
        if c in label_encoders:
            mapped = []
            le = label_encoders[c]
            for val in rookies[c]:
                try:
                    mapped.append(le.transform([val])[0])
                except:
                    mapped.append(len(le.classes_))
            rookies[c] = mapped
        else:
            rookies[c] = rookies[c].map(lambda x: hash(x) % (10**6))
    if num_cols:
        rookies[num_cols] = scaler.transform(rookies[num_cols].fillna(0))
    rookies_proba = model.predict_proba(rookies[features])[:,1]
    rookies["pred_prob_scored_points"] = rookies_proba
    display_cols = [c for c in rookies.columns if "driver" in c or "name" in c][:1] + ["pred_prob_scored_points"]
    print("\n--- 2025 rookies predicted probability of scoring points ---")
    print(rookies[display_cols].reset_index(drop=True))

print("\nDone.")




